generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model users {
  id         String   @id @default(uuid())
  phone      String   @unique
  name       String?
  created_at DateTime @default(now())
  chats      chats[]
  memory     memory[]
}

model chats {
  id           String     @id @default(uuid())
  user_id      String
  last_message String?
  unread_count Int?       @default(0)
  updated_at   DateTime?  @default(now())
  users        users      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  messages     messages[]

  @@index([user_id])
}

model messages {
  id        String    @id @default(uuid())
  chat_id   String
  sender    String
  text      String?
  timestamp DateTime? @default(now())
  status    String?
  is_media  Boolean?  @default(false)
  media_url String?
  chats     chats     @relation(fields: [chat_id], references: [id], onDelete: Cascade)

  @@index([chat_id])
}

model memory {
  id          String    @id @default(uuid())
  user_id     String
  summary     String?
  facts       String?   @default("{}")
  preferences String?   @default("{}")
  updated_at  DateTime? @default(now())
  users       users     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model settings {
  id    String @id @default(uuid())
  key   String @unique
  value String
}

model logs {
  id        String    @id @default(uuid())
  timestamp DateTime? @default(now())
  level     String?
  source    String?
  message   String?
  details   String?
}
